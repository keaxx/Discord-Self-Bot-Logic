# Railway / Local binding
PORT=8000

# Optional spam tuning defaults (overridable via query params too)
WORKERS_DEFAULT=40
REQS_PER_DEFAULT=60
DELAY_DEFAULT=0.1

# Extra proxy sources if you want to override the hardcoded list in scrape_open_proxies()
PROXY_SOURCES=https://www.sslproxies.org/,https://free-proxy-list.net/,https://www.us-proxy.org/,https://free-proxy-list.net/uk-proxy.html

# Future-proof placeholders (uncomment/add as we layer in paid proxies or auth)
# PROXY_AUTH=user:pass
# MAX_PROXIES=600
